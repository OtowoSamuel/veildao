{
  "name": "veildao",
  "version": "0.1.0",
  "description": "Encrypted DAO Treasury Management powered by Fhenix CoFHE",
  "scripts": {
    "compile": "hardhat compile",
    "clean": "hardhat clean",
    "test": "hardhat test",
    "deploy:local": "hardhat run scripts/deploy.ts --network localhost",
    "deploy:arb-sepolia": "hardhat run scripts/deploy.ts --network arbSepolia",
    "deploy:base-sepolia": "hardhat run scripts/deploy.ts --network baseSepolia",
    "deploy:eth-sepolia": "hardhat run scripts/deploy.ts --network ethSepolia",
    "localcofhe:start": "npx @cofhe/localcofhe start",
    "localcofhe:stop": "npx @cofhe/localcofhe stop"
  },
  "keywords": [
    "fhenix",
    "fhe",
    "dao",
    "treasury",
    "privacy",
    "cofhe"
  ],
  "license": "MIT",
  "devDependencies": {
    "@cofhe/hardhat-plugin": "^0.4.0",
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-ignition": "^0.15.16",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.17",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@nomicfoundation/ignition-core": "^0.15.15",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^10.0.0",
    "hardhat": "^2.22.0",
    "hardhat-gas-reporter": "^1.0.10",
    "solidity-coverage": "^0.8.17",
    "ts-node": "^10.9.0",
    "typechain": "^8.3.2",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@cofhe/sdk": "^0.4.0",
    "@fhenixprotocol/cofhe-contracts": "^0.1.3",
    "@openzeppelin/contracts": "^5.0.0",
    "dotenv": "^16.4.0",
    "ethers": "^6.13.0"
  }
}
